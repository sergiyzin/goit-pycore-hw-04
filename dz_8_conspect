HELLO = "hello"

unique_number = 0


def generate_unique_id():
    global unique_number
    unique_number += 1
    return unique_number


def generate_unique_id_alt():
    global unique_number
    unique_number -= 1
    return unique_number


def generate_unique_id_closure():
    unique_number = 0

    def generate_id():
        nonlocal unique_number
        unique_number += 1
        return unique_number

    return generate_id


# Працюємо з global-лічильником
assert generate_unique_id() == 1   # unique_number = 1
assert generate_unique_id() == 2   # unique_number = 2
assert generate_unique_id() == 3   # unique_number = 3
print(generate_unique_id_alt())    # unique_number = 2
assert generate_unique_id() == 3   # unique_number = 3


# Перший лічильник на замиканні
id_generator = generate_unique_id_closure()
assert id_generator() == 1
assert id_generator() == 2
assert id_generator() == 3
assert id_generator() == 4


# Другий незалежний лічильник на замиканні
id_generator_two = generate_unique_id_closure()
assert id_generator_two() == 1
assert id_generator_two() == 2
assert id_generator_two() == 3
assert id_generator_two() == 4
